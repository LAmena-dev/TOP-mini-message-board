<html>

<head>
    <link rel="stylesheet" href="./styles.css">
    <title>
        <%= title %>
    </title>
</head>

<body>
    <nav class="navBar">
        <h1>
            <%= title %>
        </h1>
        <div>
            <a href="/"><button type="button">Messages</button></a>
            <a href="/new"><button type="button" disabled>Add a new message</button></a>
        </div>
    </nav>

    <form method="POST" action="/new">
        <label for="user">Name:</label>
        <input type="text" id="user" name="msgUser" required><br><br>

        <label for="text">Message:</label>
        <textarea id="text" name="msgText" required></textarea><br><br>

        <button type="submit">Post Message</button>
    </form>
</body>

</html>