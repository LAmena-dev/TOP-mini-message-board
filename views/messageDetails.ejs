<html>

<head>
    <link rel="stylesheet" href="./styles.css">
    <title>
        <%= title %>
    </title>
</head>

<body>
    <nav class="navBar">
        <h1>Message Details</h1>
        <div>
            <a href="/"><button type="button">Messages</button></a>
            <a href="/new"><button type="button">Add a new message</button></a>
        </div>
    </nav>

    <p><strong>Author:</strong>
        <%= message.user %>
    </p>
    <p><strong>Message:</strong>
        <%= message.text %>
    </p>
    <p><strong>Added:</strong>
        <%= message.added.toLocaleString() %>
    </p>


</body>

</html>